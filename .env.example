# ═══════════════════════════════════════════════════════════════════
# XSS Scout — Environment Variables
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0
WORKERS=1
LOG_LEVEL=info

# ── Scanner defaults ──────────────────────────────────────────────
SCAN_WORKERS=20
SCAN_EVIDENCE_DIR=./evidence
SCAN_REPORTS_DIR=./reports

# ── Storage (leave blank to use SQLite) ───────────────────────────
# DATABASE_URL=postgresql://user:pass@host:5432/xscanner
# REDIS_URL=redis://localhost:6379/0

# ── PostgreSQL (docker-compose full profile) ──────────────────────
# POSTGRES_PASSWORD=xscanner_secret
